{
  "name": "mutinychat",
  "version": "0.1.0",
  "description": "MutinyChat is the modern revival of old-school direct-connect chat...",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:backend:sidecar": "./scripts/build-backend-sidecar.sh",
    "build:backend:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-backend-sidecar.ps1",
    "prepare:tor:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/prepare-tor-windows.ps1",
    "verify:package:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/verify-windows-package.ps1 -TargetDirectory src-tauri\\target\\x86_64-pc-windows-msvc\\release",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
    "test:frontend": "node tests/frontend/channelStatus.test.js && node tests/frontend/messageHistory.test.js && node tests/frontend/frontendEvents.test.js && node tests/frontend/torStatus.test.js && node tests/frontend/connectionStatus.test.js && node tests/frontend/backendPoll.test.js && node tests/frontend/invitationClipboard.test.js && node tests/frontend/usernamePrivacy.test.js",
    "check:frontend-network": "node scripts/check-frontend-network-resources.mjs",
    "check:tauri-csp": "node scripts/check-tauri-csp.mjs",
    "check:release-policy": "node scripts/check-release-version.mjs && node scripts/check-release-policy.mjs",
    "check:release-version": "node scripts/check-release-version.mjs",
    "check:supply-chain": "node scripts/check-supply-chain-pins.mjs",
    "test:packaged:macos": "./scripts/test-packaged-macos.sh",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "bootstrap": "^5.3.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  },
  "overrides": {
    "cookie": "0.7.2"
  }
}
